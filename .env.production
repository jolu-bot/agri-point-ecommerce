# =====================================================
# FICHIER .ENV DE PRODUCTION - AGRI POINT SERVICE
# =====================================================
# ⚠️  NE PAS COMMITER CE FICHIER SUR GITHUB
# Copiez ce contenu dans votre plateforme de déploiement
# =====================================================

# =====================================================
# 1. BASE DE DONNÉES MONGODB
# =====================================================
# ✅ MongoDB Atlas configuré
MONGODB_URI=mongodb+srv://agrips:REDACTED_PASSWORD_CHANGE_ON_ATLAS@cluster0.r4qjqcs.mongodb.net/agripoint?retryWrites=true&w=majority&appName=Cluster0

# =====================================================
# 2. SÉCURITÉ JWT (⚡ NOUVEAUX SECRETS GÉNÉRÉS)
# =====================================================
# ✅ Ces secrets ont été générés spécifiquement pour la production
# ⚠️  NE JAMAIS réutiliser les secrets de développement
JWT_SECRET=460c9147182f5a185cad919ed05d50bf98672074946f3e49309691353c25b9a2f1b1b487a18d5b4e25c7d80fd2f2ec7d3740830df194db991f2ebf39a78e246a
JWT_REFRESH_SECRET=a861b814d1463ee21bb8128a1094b85565e5f37a54a8beccb7c6c1ace4eb659c5fe1cc14a295fd953ff941c3011e3c16f7de9eb1f789decaccc1227770f82bf5

# Durée de vie des tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =====================================================
# 3. OPENAI API (AgriBot)
# =====================================================
# ✅ Utiliser la même clé que développement (ou régénérer une nouvelle)
OPENAI_API_KEY=sk-proj-votre-cle-openai

# =====================================================
# 4. STRIPE (PAIEMENTS)
# =====================================================
# 🔴 OBLIGATOIRE : Passer en mode LIVE pour production
# Dashboard Stripe → Développeurs → Clés API → Activer "Mode Production"
# Remplacer pk_test_ et sk_test_ par pk_live_ et sk_live_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_LIVE
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE_LIVE

# Webhook (optionnel, pour notifications paiement)
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK

# =====================================================
# 5. PAYPAL (PAIEMENTS)
# =====================================================
# 🔴 Passer en mode PRODUCTION
# Dashboard PayPal → Apps & Credentials → Live → Créer une app
NEXT_PUBLIC_PAYPAL_CLIENT_ID=VOTRE_CLIENT_ID_PRODUCTION
PAYPAL_CLIENT_SECRET=VOTRE_CLIENT_SECRET_PRODUCTION
# Mode : "sandbox" pour test, "production" pour live
NEXT_PUBLIC_PAYPAL_MODE=production

# =====================================================
# 6. EMAIL (NODEMAILER)
# =====================================================
# 🔴 Configurer un vrai serveur SMTP
# Options recommandées : SendGrid, Brevo (ex-Sendinblue), Mailgun, AWS SES

# Configuration SMTP classique
EMAIL_HOST=smtp.votre-serveur.com
EMAIL_PORT=587
EMAIL_USER=noreply@agripoint.com
EMAIL_PASS=votre-mot-de-passe-smtp
EMAIL_FROM=AGRI POINT SERVICE <noreply@agripoint.com>

# Exemples de configuration pour fournisseurs populaires :
# 
# BREVO (ex-Sendinblue) - Gratuit jusqu'à 300 emails/jour
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USER=votre-email@gmail.com
# EMAIL_PASS=votre-cle-api-brevo
#
# SENDGRID - Gratuit jusqu'à 100 emails/jour
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.votre-cle-api-sendgrid
#
# GMAIL (nécessite mot de passe d'application)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=votre-email@gmail.com
# EMAIL_PASS=mot-de-passe-application-16-caracteres

# =====================================================
# 7. URL DU SITE
# =====================================================
# 🔴 OBLIGATOIRE : Remplacer par votre domaine de production
# Exemples : https://agripoint.com ou https://votre-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# =====================================================
# 8. ENVIRONNEMENT
# =====================================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# =====================================================
# 9. ADMIN PAR DÉFAUT (PREMIÈRE CONNEXION)
# =====================================================
# Ces informations servent à créer le compte admin initial
# Changer le mot de passe après première connexion !
ADMIN_EMAIL=admin@agripoint.com
ADMIN_PASSWORD=Admin2024!Secure

# =====================================================
# INSTRUCTIONS DE DÉPLOIEMENT
# =====================================================
#
# 📋 CHECKLIST AVANT DÉPLOIEMENT :
#
# ✅ 1. MongoDB Atlas (ou VPS MongoDB)
#    - Créer cluster gratuit M0 sur https://cloud.mongodb.com
#    - Créer database user (Database Access)
#    - Whitelist IP : 0.0.0.0/0 (Network Access)
#    - Copier connection string dans MONGODB_URI
#
# ✅ 2. Stripe Live Keys
#    - Dashboard Stripe : https://dashboard.stripe.com
#    - Développeurs → Clés API
#    - Activer "Afficher les clés en direct"
#    - Copier Clé publiable (pk_live_...) et Clé secrète (sk_live_...)
#
# ✅ 3. PayPal Production
#    - Dashboard PayPal : https://developer.paypal.com
#    - Apps & Credentials → Live
#    - Créer une application ou utiliser existante
#    - Copier Client ID et Secret
#
# ✅ 4. Email SMTP
#    - Choisir fournisseur (Brevo recommandé pour débutants)
#    - Créer compte gratuit
#    - Générer clé API SMTP
#    - Configurer EMAIL_HOST, EMAIL_USER, EMAIL_PASS
#
# ✅ 5. URL Production
#    - Remplacer NEXT_PUBLIC_SITE_URL par votre domaine
#
# =====================================================
# COMMENT UTILISER CE FICHIER ?
# =====================================================
#
# 🖥️  VPS (Hostinger, OVH, DigitalOcean...) :
#    1. SSH : ssh root@votre-serveur.com
#    2. cd /var/www/agri-point-ecommerce
#    3. nano .env.local
#    4. Coller le contenu ci-dessus (modifié)
#    5. Ctrl+X, Y, Enter pour sauvegarder
#
# ☁️  VERCEL :
#    1. Dashboard → Votre projet → Settings
#    2. Environment Variables
#    3. Ajouter chaque variable une par une
#    4. Ou utiliser Vercel CLI : vercel env pull
#
# 🚂 RAILWAY :
#    1. Dashboard → Votre projet → Variables
#    2. Raw Editor
#    3. Coller tout le contenu (sans commentaires)
#
# ☁️  RENDER / NETLIFY / AWS :
#    - Similaire à Vercel (interface variables)
#
# =====================================================
