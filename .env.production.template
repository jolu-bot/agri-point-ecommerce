# 📝 COMMANDES UTILES
# ═══════════════════════════════════════════════════════════════
#
# Générer JWT secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Ajouter variable à Vercel:
#   vercel env add MONGODB_URI production
#
# Lister variables Vercel:
#   vercel env ls production
#
# Supprimer variable Vercel:
#   vercel env rm NOM_VARIABLE production
#
# Tester connexion MongoDB:
#   node -e "require('mongoose').connect('votre-uri').then(() => console.log('✓ Connected')).catch(console.error)"
#
# Tester email SMTP:
#   node scripts/test-email.js
