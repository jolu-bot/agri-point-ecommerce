{
  "name": "agri-point-ecommerce",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/post-build-optimize.js",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "seed": "node scripts/seed.js",
    "seed:config": "node scripts/seed-site-config.js",
    "seed:users": "node scripts/seed-users.js",
    "seed:orders": "node scripts/seed-orders.js",
    "seed:campaign": "node scripts/seed-campaign-march-2026.js",
    "seed:campaign:products": "node scripts/seed-campaign-products.js",
    "seed:all": "npm run seed && npm run seed:users && npm run seed:orders",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next node_modules",
    "reset": "npm run clean && npm install",
    "analyze": "ANALYZE=true npm run build",
    "analyze:bundle": "node scripts/bundle-analyzer.js",
    "perf": "node scripts/analyze-performance.js",
    "optimize": "npm run lint && npm run type-check && npm run build",
    "cron:backup": "bash scripts/mongodb-backup-cron.sh",
    "cron:publish": "node --require ts-node/register scripts/scheduled-publishing-cron.ts",
    "status": "node scripts/status.js",
    "generate:hero": "node scripts/generate-campaign-hero.js",
    "test:sms": "node scripts/test-sms-provider.js",
    "test:sms:prod": "SMS_PROVIDER=infobip node scripts/test-sms-provider.js",
    "generate:qr": "node scripts/generate-qr-codes.js",
    "pre-launch-tests": "node scripts/pre-launch-tests.js",
    "monitor:agent": "node scripts/monitoring-agent.js",
    "export:payments": "node scripts/export-payments.js",
    "dashboard:generate": "node scripts/generate-dashboard-data.js",
    "pm2:monitor:start": "pm2 start scripts/monitoring-agent.js --name monitoring-agent",
    "pm2:monitor:stop": "pm2 stop monitoring-agent || true",
    "test:export": "node scripts/test-export-payments-mock.js",
    "push:gas": "node scripts/push-to-gas.js",
    "push:grafana": "node scripts/grafana/push-to-grafana.js",
    "campaign:activate": "node scripts/activate-campaign-now.js",
    "campaign:test": "node scripts/test-campaign-visibility.js",
    "campaign:go-live": "node scripts/activate-campaign-complete.js"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.4.2",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/nextjs": "^10.42.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/leaflet": "^1.9.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@upstash/redis": "^1.36.3",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.0.1",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.15.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "mongoose": "^8.8.4",
    "multer": "^2.0.2",
    "next": "^16.1.6",
    "next-themes": "^0.4.4",
    "nodemailer": "^7.0.11",
    "openai": "^4.76.1",
    "otplib": "^13.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "postcss": "^8",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.68.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.4.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.0",
    "resend": "^6.9.3",
    "swr": "^2.3.7",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "uuid": "^13.0.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.1"
  }
}
