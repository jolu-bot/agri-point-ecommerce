# Template Variables d'Environnement - Production
# Date: 1er mars 2026
# 
# INSTRUCTIONS:
# 1. Copier ce fichier en .env.production.local (ne PAS commiter)
# 2. Remplir toutes les valeurs entre < >
# 3. Utiliser le script: .\add-env-to-vercel.ps1
# OU ajouter manuellement via: vercel env add NOM_VARIABLE production

# ═══════════════════════════════════════════════════════════════
# 🗄️ BASE DE DONNÉES
# ═══════════════════════════════════════════════════════════════

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
# Obtenir: https://cloud.mongodb.com → Database → Connect
MONGODB_URI=<mongodb+srv://votre-user:votre-password@cluster.mongodb.net/agri-ps?retryWrites=true&w=majority>

# ═══════════════════════════════════════════════════════════════
# 🔐 SÉCURITÉ & AUTHENTIFICATION
# ═══════════════════════════════════════════════════════════════

# JWT Secret (minimum 32 caractères aléatoires)
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<votre-jwt-secret-32-caracteres-minimum>

# JWT Refresh Token Secret (différent de JWT_SECRET)
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=<votre-refresh-secret-different-32-caracteres>

# NextAuth Secret (si vous utilisez NextAuth)
# Générer: openssl rand -base64 32
NEXTAUTH_SECRET=<votre-nextauth-secret-si-utilise>

# ═══════════════════════════════════════════════════════════════
# 📧 EMAIL (Nodemailer) - CRITIQUE pour Phase 4
# ═══════════════════════════════════════════════════════════════

# SMTP Host
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Autre: Vérifier config de votre provider
EMAIL_HOST=smtp.gmail.com

# SMTP Port
# Généralement: 587 (TLS) ou 465 (SSL)
EMAIL_PORT=587

# Email utilisateur (compte d'envoi)
# Pour Gmail: Activer "App Passwords" dans Google Account
# https://myaccount.google.com/apppasswords
EMAIL_USER=<noreply@agri-ps.com>

# App Password (PAS le mot de passe du compte)
# Gmail: Générer un "App Password" (16 caractères)
# Outlook: Mot de passe du compte
EMAIL_PASS=<votre-app-password-16-caracteres>

# Email expéditeur (affiché au destinataire)
EMAIL_FROM=noreply@agri-ps.com

# ═══════════════════════════════════════════════════════════════
# ⭐ PHASE 4 - NOTIFICATIONS (CRITIQUE)
# ═══════════════════════════════════════════════════════════════

# Email de l'administrateur (reçoit notifications upload)
# Utilisé dans: app/api/orders/upload-receipt/route.ts
ADMIN_EMAIL=<admin@agri-ps.com>

# ═══════════════════════════════════════════════════════════════
# 🌐 SITE & DOMAINE
# ═══════════════════════════════════════════════════════════════

# URL publique du site (sans trailing slash)
# ⚠️ IMPORTANT: Mettre URL Vercel d'abord, puis domaine custom après config
# Première fois: https://agri-point-ecommerce.vercel.app
# Après domaine custom: https://agri-ps.com
NEXT_PUBLIC_SITE_URL=<https://agri-point-ecommerce.vercel.app>

# NextAuth URL (même que NEXT_PUBLIC_SITE_URL généralement)
NEXTAUTH_URL=<https://agri-point-ecommerce.vercel.app>

# ═══════════════════════════════════════════════════════════════
# 📊 ANALYTICS & MONITORING (Optionnel)
# ═══════════════════════════════════════════════════════════════

# Google Analytics (si utilisé)
# NEXT_PUBLIC_GA_ID=<G-XXXXXXXXXX>

# Sentry DSN (error tracking)
# SENTRY_DSN=<https://xxx@sentry.io/xxx>

# ═══════════════════════════════════════════════════════════════
# 🔧 AUTRES CONFIGURATIONS (Optionnel)
# ═══════════════════════════════════════════════════════════════

# Node Environment (automatique sur Vercel)
# NODE_ENV=production

# ═══════════════════════════════════════════════════════════════
