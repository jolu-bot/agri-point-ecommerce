# AGRI POINT — Environment Variables Configuration
# Copy this to .env.local for development or .env.production.local for production

# ──────────────────────────────────────────────────────────────────────────
# DATABASE (MongoDB via Mongoose)
# ──────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/agri-point?retryWrites=true&w=majority
MONGODB_URI_OFFLINE=mongodb://localhost:27017/agri-point-offline

# ──────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (JWT Tokens)
# ──────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_token_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_here
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# ──────────────────────────────────────────────────────────────────────────
# SITE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://agri-ps.com
NEXT_PUBLIC_SITE_NAME=Agri-PS
NODE_ENV=production
VERCEL_REGION=iad

# ──────────────────────────────────────────────────────────────────────────
# PHASE 3: MONITORING & LOGGING
# ──────────────────────────────────────────────────────────────────────────

# Application Version (used in /api/health endpoint)
APP_VERSION=1.0.0

# Logging Level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Sentry Error Tracking (https://sentry.io)
# 1. Create Sentry account and project
# 2. Copy DSN from project settings
# 3. Get auth token from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_DSN=https://key@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-project-name
SENTRY_AUTH_TOKEN=your-auth-token-for-sourcemap-upload
SENTRY_ENVIRONMENT=production

# Health Check Configuration
# Used by Vercel, K8s probes, load balancers
HOSTNAME=agri-ps-app-1

# ──────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (SMTP)
# ──────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@agri-ps.com
SMTP_FROM_NAME=Agri-PS

# ──────────────────────────────────────────────────────────────────────────
# SMS SERVICE (Twilio)
# ──────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────────────────────────────────────
# FILE UPLOAD (Cloudinary or AWS S3)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Alternative: AWS S3
# AWS_S3_BUCKET=agri-ps-uploads
# AWS_S3_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ──────────────────────────────────────────────────────────────────────────
# PAYMENT GATEWAYS
# ──────────────────────────────────────────────────────────────────────────
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal
PAYPAL_CLIENT_ID=AY...
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=live

# ──────────────────────────────────────────────────────────────────────────
# GOOGLE SERVICES (OAuth, Analytics, Maps)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxx

# ──────────────────────────────────────────────────────────────────────────
# CONTENT & SEO
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_DESCRIPTION=Agri-PS: Solutions agricoles périurbaines et urbaines
NEXT_PUBLIC_SITE_KEYWORDS=agriculture,urbaine,périurbaine,engrais,semences
NEXT_PUBLIC_SITE_AUTHOR=Agri-PS Team
NEXT_PUBLIC_OG_IMAGE=https://agri-ps.com/og-image.png

# ──────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS (for A/B testing, gradual rollouts)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AGRIBOT=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHECKOUT=true

# ──────────────────────────────────────────────────────────────────────────
# DEVELOPER TOOLS (dev only)
# ──────────────────────────────────────────────────────────────────────────
# Enable debug logging in development
DEBUG=true

# Mock external services for local development
MOCK_EMAIL=false
MOCK_SMS=false
MOCK_PAYMENT=true

# ──────────────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS
# ──────────────────────────────────────────────────────────────────────────

# Grafana Cloud (metrics/monitoring)
GRAFANA_API_KEY=xxx
GRAFANA_ORG_ID=xxx

# Datadog (APM)
DD_API_KEY=xxx
DD_SITE=datadoghq.eu

# ──────────────────────────────────────────────────────────────────────────
# SECURITY & COMPLIANCE
# ──────────────────────────────────────────────────────────────────────────
# Rate limiting (redis for production, in-memory for dev)
REDIS_URL=redis://localhost:6379

# CORS allowed origins
NEXT_PUBLIC_ALLOWED_ORIGINS=https://agri-ps.com,https://www.agri-ps.com,http://localhost:3000

# Content Security Policy
NEXT_PUBLIC_CSP_NONCE=generated_at_build_time

# ──────────────────────────────────────────────────────────────────────────
# DEPLOYMENT (Vercel specific)
# ──────────────────────────────────────────────────────────────────────────
VERCEL_PROJECT_ID=xxx
VERCEL_TEAM_ID=xxx
VERCEL_GIT_PROVIDER=github
VERCEL_GIT_REPO_OWNER=agri-ps
VERCEL_GIT_REPO_SLUG=agri-point-ecommerce
